<?xml version="1.0" encoding="utf-8" ?> 
<%! eval(utils.include("wspolne.js")) %>
<%!
    /* --- Teksty --- */
    let tytuly = {
        MOC_DAWKI: "MOCY DAWKI",
        EMISJA_POWIERZCHNIOWA: "EMISJI POWIERZCHNIOWEJ",
    };
    let literaArkusza = {
        MOC_DAWKI: "c",
        EMISJA_POWIERZCHNIOWA: "s",
    };

    /* --- Kolory --- */
    globalThis.$tn = "#004168"; /* Tekst nagłówka */
    globalThis.$jt = "#53788F"; /* Jaśniejszy tekst nagłówka */
    globalThis.$ct = "#53788F"; /* Ciemne tło tabeli i stopki */
    globalThis.$rm = "#7b97a9"; /* Ramki tabeli i strony  */
    globalThis.$nj = "#a3bbcb"; /* Nagłówek jasny */

    tabela = tabela.filter(r => r.dolacz);
%>
<document>

  <p-style id="Normal" name="Normal">
    <font face="Aptos" size="9pt"/>
  </p-style>

  <DEF:kom valign="middle" margin="1.0mm 1.6mm" border="0.2mm <% $rm %>"/>
  <DEF:head valign="middle" margin="1.8mm 2mm" border="0.2mm <% $rm %>"/>
  <DEF:TODO><b color="red">⚠TODO: </b></DEF:TODO>
  <DEF:ERROR><b color="red">⚠ERROR⚠</b></DEF:ERROR>

  <section
      border="single <% $rm %> 0.2mm 4mm, single <% $rm %> 0.2mm 4mm, single <% $rm %> 0.2mm 0mm, single <% $rm %> 0.2mm 4mm"
      width="21cm" height="29.7cm"
      margin="1.2cm 1.4cm 0cm 1.4cm" footer-margin="8mm"/>

  <!--

    szerokość:
        strona: 21cm
        marginesy: 2x1.4cm
        bez marginesów: 18.2cm

  -->

    <!-- STOPKA -->
    <footer>
      <p tabs="0.7cm, 17.5cm right" background="<% $ct %>">
        <tab/><b color="white">F1/WZOR-2/11.23.1234<tab/>Strona <page-number/> z <total-pages/></b>
      </p>
    </footer>

    <!-- TABELA NAGŁÓWKOWA -->
    <table width="18.2cm" border="nil">
        <tc width="1.7cm"/>
        <tc width="5.2cm"/>
        <tc width="5.7cm"/>
        <tc width="5.6cm"/>
        <tr>
            <!-- LOGO -->
            <td valign="middle" margin="0mm" border="nil">
                <img src="img/ifj.png" width="1.6cm" height="1.453cm" />
            </td>
            <!-- LABORATORIUM WZORCOWANIA PRZYRZĄDÓW DOZYMETRYCZNYCH -->
            <td valign="middle" margin="0mm 0mm 0mm 3mm" border="nil, <% $rm %> single 0.2mm 0mm, nil, nil">
                <p line-spacing="exactly 1.2">
                <font face="Aptos Narrow" size="8.5pt" color="<% $tn %>">LABORATORIUM WZORCOWANIA
                PRZYRZĄDÓW DOZYMETRYCZNYCH</font>
                </p>
            </td>
            <!-- PROTOKÓŁ -->
            <td valign="middle" margin="0mm 3mm 0mm 3mm" border="nil, <% $rm %> single 0.2mm 0mm, nil, <% $rm %> single 0.2mm 0mm">
                <p line-spacing="exactly 1.2">
                <font face="Aptos Narrow" size="14pt" color="<% $tn %>" bold="1">PROTOKÓŁ</font>
                <br/><font face="Aptos Narrow" size="10pt" color="<% $jt %>">WZORCOWANIE W ZAKRESIE
                <br/><% tytuly[typ] %></font>
                </p>
            </td>
            <!-- IDENTYFIKACJA -->
            <td valign="middle" margin="0mm 3mm 0mm 3mm" border="nil, nil, nil, <% $rm %> single 0.2mm 0mm">
                <p spacing="0mm 2mm">
                    <font face="Aptos Narrow" size="8pt" color="<% $jt %>">Znak sprawy:<br/></font
                    ><font face="Aptos Narrow" size="9pt"><% znakSprawy %></font>
                </p>
                <p tabs="1.4cm, 3.2cm">
                    <font face="Aptos Narrow" size="8pt" color="<% $jt %>">Nr karty:<tab/>Nr arkusza:<tab/>Data:<br/></font
                    ><font face="Aptos Narrow" size="9pt"><b face="Aptos Black"><% nrKarty %></b><tab
                        /><% nrArkusza %><% literaArkusza[typ] %><tab/><% tekst(data, 'ksiegowa') %></font>
                </p>
            </td>
        </tr>
    </table>

    <p>&nbsp;</p>

    <table border="nil">
    <tc width="9.7cm"/>
    <tc width="8.5cm"/>
    <tr><td border="nil" valign="top" margin="0mm">


    <!-- TABELA: INFORMACJE OGÓLNE -->
    <table align="left">
        <tc width="3.9cm"/>
        <tc width="5.8cm"/>
        <tr>
            <td:head colspan="2" background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/opcje.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm"  />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. INFORMACJE OGÓLNE</b></font>
                </p>
            </td:head>
        </tr>
        <tr><td:kom>Metoda wzorcowania</td:kom><td:kom>
            <%!
                /* Sortujemy metody po dacie od najnowszej do najstarszej */
                metody.sort((a, b) => b.DataRozpoczecia.znacznik - a.DataRozpoczecia.znacznik);
                /* Znajdź najnowszą metodę, która jest nie późniejsza niż data wzorcowania */
                let metoda = metody.find(m => m.DataRozpoczecia.znacznik <= data.znacznik);
            %>
            <%= escape(metoda.Tekst).replace(new RegExp("\\s*\\("), '<br/>(') %>
        </td:kom></tr>
        <tr><td:kom>Stanowisko pomiarowe</td:kom><td:kom>Hala kalibracyjna stanowisko WZOR‑1</td:kom></tr>
    </table>


    </td><td border="nil" valign="top" margin="0mm">

    <!-- TABELA: DANE ZLECENIODAWCY -->
    <table align="right">
        <tc width="3.0cm"/>
        <tc width="5.1cm"/>
        <tr>
            <td:head colspan="2" background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/user.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm" />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. DANE ZLECENIODAWCY</b></font>
                </p>
            </td:head>
        </tr>
        <tr><td:kom>Zleceniodawca</td:kom><td:kom><% zleceniodawca.Zleceniodawca %></td:kom></tr>
        <tr><td:kom>ID klienta</td:kom><td:kom><% zleceniodawca.ID_zleceniodawcy %></td:kom></tr>
    </table>

    </td></tr>
    </table>

    <p>&nbsp;</p>

    <!-- TABELA: DANE PRZYRZĄDU -->

    <table border="nil">
    <tc width="11.1cm"/>
    <tc width="0.4cm"/>
    <tc width="6.7cm"/>
    <tr><td colspan="3" border="nil" valign="top" margin="0mm">

    <!-- POD-TABELA: DANE PRZYRZĄDU > Nagłówek -->
    <table border="nil">
    <tc width="18.2cm"/>
    <tr>
      <td:head background="<% $nj %>">
        <p tabs="7.7mm">
          <img src="img/licznik.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm" />
          <font color="<% $tn %>"><tab/><b><% numeruj() %>. DANE PRZYRZĄDU</b></font>
        </p>
      </td:head>
    </tr>
    </table>

    </td></tr>
    <tr><td border="nil" valign="top" margin="0.05mm 0mm 0mm">

    <!-- POD-TABELA: DANE PRZYRZĄDU > PRZYRZĄD -->
    <table>
        <tc width="3.0cm"/>
        <tc width="8.1cm"/>
        <tr>
            <td:kom colspan="2" border="nil, 0.2mm <% $rm %>, 0.2mm <% $rm %>"><b color="<% $tn %>">PRZYRZĄD</b></td:kom>
        </tr>
        <tr>
            <td:kom>Typ</td:kom><td:kom><% przyrzad.typ %></td:kom>
        </tr>
        <tr>
            <td:kom>Nr fabryczny</td:kom><td:kom><% przyrzad.nrFabryczny %></td:kom>
        </tr>
        <tr>
            <td:kom>ID przyrządu</td:kom><td:kom><% kartaPrzyjecia.ID_dozymetru %></td:kom>
        </tr>
        <%! if (typ === 'EMISJA_POWIERZCHNIOWA') { %>
        <tr>
            <td:kom>Zakres pomiarowy</td:kom><td:kom><% emisjaPow.zakres %></td:kom>
        </tr>
        <%! } %>
        <tr>
            <td:kom>Inne nastawy</td:kom><td:kom><% przyrzad.inneNastawy %></td:kom>
        </tr>
    </table>

    </td>
    <td border="nil" margin="0mm"></td>
    <td border="nil" valign="top" margin="0.05mm 0mm 0mm">

    <!-- POD-TABELA: DANE PRZYRZĄDU > SONDA -->
    <table>
        <tc width="3.0cm"/>
        <tc width="3.7cm"/>
        <tr>
            <td:kom colspan="2" border="nil, 0.2mm <% $rm %>, 0.2mm <% $rm %>"><b color="<% $tn %>">SONDA</b></td:kom>
        </tr>
        <tr>
            <td:kom>Typ</td:kom><td:kom><% przyrzad.sondaTyp %></td:kom>
        </tr>
        <tr>
            <td:kom>Nr fabryczny</td:kom><td:kom><% przyrzad.sondaNrFabryczny %></td:kom>
        </tr>
        <tr>
            <td:kom>ID sondy</td:kom><td:kom><% sonda.ID_sondy %></td:kom>
        </tr>
        <tr>
            <td:kom>Napięcie zasilania</td:kom><td:kom><% przyrzad.napiecieZasilaniaSondy %><% przyrzad.napiecieZasilaniaSondy.match(/^\s*[0-9.,-]+\s*$/) ? " V" : "" %></td:kom>
        </tr>
    </table>

    </td>
    </tr>
    </table>

    <p>&nbsp;</p>

    <table border="nil">
    <tc width="11.1cm"/>
    <tc width="0.4cm"/>
    <tc width="6.7cm"/>
    <tr><td border="nil" valign="top" margin="0.05mm 0mm 0mm">

    <%! if (typ !== 'EMISJA_POWIERZCHNIOWA') { %>

    <table>
        <tc width="3.5cm"/>
        <tc width="7.6cm"/>
        <tr>
            <td:head colspan="2" background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/prom.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm"  />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. INFORMACJE O WZORCOWANIU</b></font>
                </p>
            </td:head>
        </tr>
        <tr>
            <td:kom>Wielkość fizyczna</td:kom><td:kom><% wielkoscFizyczna %></td:kom>
        </tr>
        <tr>
            <td:kom>Tło</td:kom><td:kom><% tlo %> <% jednostka %></td:kom>
        </tr>
    </table>

    <%! } else { %>

    <table>
        <tc width="3.5cm"/>
        <tc width="7.6cm"/>
        <tr>
            <td:head colspan="2" background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/prom.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm"  />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. ŹRÓDŁO</b></font>
                </p>
            </td:head>
        </tr>
        <tr>
            <td:kom>Rodzaj</td:kom><td:kom><b><% emisjaPow.zrodlo.Nazwa %></b></td:kom>
        </tr>
        <tr>
            <td:kom>Nr źródła</td:kom><td:kom><% emisjaPow.zrodlo.Numer %></td:kom>
        </tr>
        <tr>
            <td:kom>Aktualna emisja pow.</td:kom><td:kom><% fixed(emisjaPow.emisjaPowierzchniowa, 2) %> cm<sup>-2</sup>s<sup>-1</sup></td:kom>
        </tr>
    </table>

    <%! } %>

    </td>
    <td border="nil" margin="0mm"></td>
    <td border="nil" valign="top" margin="0.05mm 0mm 0mm">

    <!-- POD-TABELA: INFORMACJE O WZORCOWANIU > WARUNKI ATMOSFERYCZNE -->
    <table>
        <tc width="3.7cm"/>
        <tc width="3.0cm"/>
        <tr>
            <td:head colspan="2" background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/chmura.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm"  />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. WARUNKI ATMOSFERYCZNE</b></font>
                </p>
            </td:head>
        </tr>
        <tr>
            <td:kom>Ciśnienie</td:kom><td:kom><% warunki.cisnienie %> hPa</td:kom>
        </tr>
        <tr>
            <td:kom>Temperatura</td:kom><td:kom><% warunki.temperatura %> °C</td:kom>
        </tr>
        <tr>
            <td:kom>Wilgotność względna</td:kom><td:kom><% warunki.wilgotnosc %> %</td:kom>
        </tr>
    </table>

    </td>
    </tr>
    </table>

    <p>&nbsp;</p>

    <!-- TABELA: WYNIKI -->

    <%!
    if (typ === 'EMISJA_POWIERZCHNIOWA') {
        %><%= utils.include("wzorcowanie_wzor_emisja_pow.xml") %><%!
    } else {
        %><%= utils.include("wzorcowanie_wzor_moc_dawki.xml") %><%!
    }
    %>

    <p>&nbsp;</p>

    <!-- TABELA: UWAGI -->
    <table>
        <tc width="18.2cm"/>
        <tr>
            <td:head background="<% $nj %>">
                <p tabs="7.7mm">
                    <img src="img/komentarz.png" width="6.5mm" height="6.5mm" vertical="paragraph -1.4mm" horizontal="character 0mm" />
                    <font color="<% $tn %>"><tab/><b><% numeruj() %>. UWAGI</b></font>
                </p>
            </td:head>
        </tr>
        <tr>
            <td:kom><%= simpleHtml(uwagi) %></td:kom>
        </tr>
    </table>

    <p>&nbsp;</p>


    <table>
        <tc width="8.9cm"/>
        <tc width="0.4cm"/>
        <tc width="8.9cm"/>
        <tr>
            <td:head margin="3mm 2mm">
                <p tabs="7.7mm">
                    <img src="img/osoba.png" width="6.5mm" height="6.5mm" vertical="paragraph 0.5mm" horizontal="character 0mm" />
                    <font><tab/>Wykonał(a):<br/><tab/><b><% wykonal %></b></font>
                </p>
            </td:head>
            <td border="nil"></td>
            <td:head margin="3mm 2mm">
                <p tabs="7.7mm">
                    <img src="img/tarcza.png" width="6.5mm" height="6.5mm" vertical="paragraph 0.5mm" horizontal="character 0mm" />
                    <font><tab/>Sprawdził(a):<br/><tab/><b><% sprawdzil %></b></font>
                </p>
            </td:head>
        </tr>
    </table>

    <p>
    </p>
</document>
